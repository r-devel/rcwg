                                "type": "text",
                                "text": "\n     ave(3:4, c(1.0, 1.5), c(5.5, 5.0))\n \n which should return "
                            },
                            {
                                "type": "text",
                                "text": "3 4",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": ", but returns "
                            },
                            {
                                "type": "text",
                                "text": "3.5 3.5",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": "."
                            }
                        ],
                        "contains_padding": true
                    },
                    {
                        "type": "rich_text_section",
                        "elements": [
                            {
                                "type": "text",
                                "text": "\n\nNote that under "
                            },
                            {
                                "type": "text",
                                "text": "options(OutDec = \",\")",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": ", it does return the expected result ...\nThis is of course related to character conversion and "
                            },
                            {
                                "type": "text",
                                "text": "interaction",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": "'s default\n"
                            },
                            {
