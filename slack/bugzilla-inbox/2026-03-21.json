                                "type": "link",
                                "url": "https:\/\/bugs.r-project.org\/show_bug.cgi?id=19019"
                            },
                            {
                                "type": "text",
                                "text": "\n\n--- Comment #8 from Elin Waring ("
                            },
                            {
                                "type": "link",
                                "url": "mailto:elin.waring@gmail.com",
                                "text": "elin.waring@gmail.com"
                            },
