                                "type": "text",
                                "text": "*tmp*",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": ")\n\n.\n\nIt has the same effect as\n\n    tmp = df$c\n    tmp[3:4] = 9:10\n    df$c = tmp\n\n.\n\nWith initially\n\n    df = data.frame(a = 1:4, b = 5:8)\n\n,\n\n    tmp = df$c # NULL\n    tmp[3:4] = 9:10 # tmp has length 4, NA at 1,2\n    df$c = tmp\n\n."
                            }
