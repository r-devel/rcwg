                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": ", c, value=\"[<-\"(\"$\"("
                            },
                            {
                                "type": "text",
                                "text": "*tmp*",
                                "style": {
                                    "code": true
                                }
                            },
