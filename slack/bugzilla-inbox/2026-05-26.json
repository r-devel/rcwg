                                "type": "text",
                                "text": "mousemove <- function(buttons, x, y) {\n    cat(sprintf(\"mousemove   buttons=%s x=%.3f y=%.3f\\n\", toString(buttons), x,\ny))\n    NULL\n}\nmousedown <- function(buttons, x, y) {\n    cat(sprintf(\"mousedown   buttons=%s x=%.3f y=%.3f\\n\", toString(buttons), x,\ny))\n    NULL\n}\nmouseup <- function(buttons, x, y) {\n    cat(sprintf(\"mouseup     buttons=%s x=%.3f y=%.3f\\n\", toString(buttons), x,\ny))\n    NULL\n}\nkeystroke <- function(key) {\n    cat(sprintf(\"keystroke   key=%s\\n\", key))\n    NULL\n}\n\nif (identical(.Platform$OS.type, \"unix\")) {\n    x11(type = \"Xlib\")\n} else {\n    windows()\n}\npar(mar = c(0, 0, 0, 0))\nplot.new()\ngetGraphicsEvent(onMouseMove = mousemove, onMouseDown = mousedown,\n                 onMouseUp = mouseup, onKeybd = keystroke)\n"
                            }
                        ]
                    },
