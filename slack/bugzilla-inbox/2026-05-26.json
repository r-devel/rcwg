                        "type": "rich_text_section",
                        "elements": [
                            {
                                "type": "text",
                                "text": "\n\nNote unlike with "
                            },
                            {
                                "type": "text",
                                "text": "X11",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " where scrolling are modeled as discrete button presses\nthat instead Windows scrolling events also have information about scrolling\ndeltas.  Currently the magnitudes of these scrolling deltas are being ignored\nsince "
                            },
                            {
                                "type": "text",
                                "text": "doMouseEvent",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " currently does not have the signature to support passing\nsuch scroll delta information.\n\nOne side effect of this patch is that in "
                            },
                            {
                                "type": "text",
                                "text": "windows()",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " scrolling should now\nterminate "
                            },
                            {
                                "type": "text",
                                "text": "locator()",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " which will match the current "
                            },
                            {
                                "type": "text",
                                "text": "x11()",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " behavior.  For\n"
                            },
                            {
                                "type": "text",
                                "text": "locator()",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " what should happen for "
                            },
                            {
                                "type": "text",
                                "text": "windows()",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " isn't documented but for "
                            },
                            {
                                "type": "text",
                                "text": "X11()",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": "\nit says:\n\n"
                            }
                        ]
                    },
                    {
                        "type": "rich_text_quote",
                        "elements": [
                            {
                                "type": "text",
                                "text": "For the usual 'X11' device the identification process is terminated by pressing any mouse button other than the first."
                            }
