                        "value": "<https:\/\/github.com\/daroczig|@daroczig>, <https:\/\/github.com\/MichaelChirico|@MichaelChirico>, <https:\/\/github.com\/azeloc|@azeloc>, <https:\/\/github.com\/beatrizmilz|@beatrizmilz>",
                        "title": "Assignees",
