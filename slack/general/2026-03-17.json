                ]
            }
        ]
    },
    {
        "user": "U081Z9041A5",
        "type": "message",
        "ts": "1773772688.790609",
        "edited": {
            "user": "U081Z9041A5",
            "ts": "1773773668.000000"
        },
        "client_msg_id": "0419bf61-87c5-46f9-8141-3977b4d711c0",
        "text": "What is it that you really want to know?   Package _may_ depend on a _minimal_ R version, this makes sense as they make use facilities added a by a particular R version. Examples are when vignette processing changed etc.  But other CRAN packages do _not_ specify a minimum R version, or a dependency on R at all as this is implicit.  E.g. my small package `zigg` which wraps a simple set of (fast) C language random number generators does not declare a depends at all, see <https:\/\/cran.r-project.org\/package=zigg>.  I probably have other like that, as well as packages with a stale 'Depend:' on R in an old version. In fact I removed one of those this week.  So in short it may depend on what your package does, and if any of that is dependent on a particular minimal R version.",
        "team": "T01DW9DLB2A",
        "user_team": "T01DW9DLB2A",
        "source_team": "T01DW9DLB2A",
        "user_profile": {
            "avatar_hash": "g4e96ca7ae02",
            "image_72": "https:\/\/secure.gravatar.com\/avatar\/4e96ca7ae02c37e7d940d17997d780e5.jpg?s=72&d=https%3A%2F%2Fa.slack-edge.com%2Fdf10d%2Fimg%2Favatars%2Fava_0023-72.png",
            "first_name": "Dirk",
            "real_name": "Dirk Eddelbuettel",
            "display_name": "Dirk Eddelbuettel",
            "team": "T01DW9DLB2A",
            "name": "edd",
            "is_restricted": false,
            "is_ultra_restricted": false
        },
        "blocks": [
            {
                "type": "rich_text",
                "block_id": "UmzU0",
                "elements": [
                    {
                        "type": "rich_text_section",
                        "elements": [
                            {
                                "type": "text",
                                "text": "What is it that you really want to know?   Package "
