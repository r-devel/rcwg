                        "type": "rich_text_section",
                        "elements": [
                            {
                                "type": "text",
                                "text": "Hi. I wonder if anyone knows how it is possible for packages on CRAN not have a depends value for R version? I am looking at the data with "
                            },
                            {
                                "type": "text",
                                "text": "tools::CRAN_package_db()",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " . Among other funny things I see is "
                            },
                            {
                                "type": "text",
                                "text": "R (>= 7.3-0)",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " . "
                            },
                            {
                                "type": "emoji",
                                "name": "slightly_smiling_face",
                                "unicode": "1f642"
                            },
                            {
                                "type": "text",
                                "text": "\nDoesn't CRAN enforce a check on a correct R version in the proper format for a package?"
                            }
                        ]
