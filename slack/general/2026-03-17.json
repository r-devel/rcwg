    {
        "user": "U04TQ0GBJ04",
        "type": "message",
        "ts": "1773777320.710809",
        "client_msg_id": "5ba71b29-43ee-4ff8-a09d-c499dd532958",
        "text": "Thanks! I forgot that is possible to have a package that does have an explicit dependency on R -- though there I would have guessed it is a data package.\n\nI got curious about this because of a long discussion with a coworker regarding R versions and packages and decided to have a look how that dependency is  declared on CRAN.\n\nThen i started to see some really weird R version being declared for example: <https:\/\/cran.r-project.org\/web\/packages\/cramer\/index.html> and I wonder if that is then correct or not.",
        "team": "T01DW9DLB2A",
        "user_team": "T01DW9DLB2A",
        "source_team": "T01DW9DLB2A",
        "user_profile": {
            "avatar_hash": "gb7165c7adcc",
            "image_72": "https:\/\/secure.gravatar.com\/avatar\/b7165c7adcc4f536e01e72e671815259.jpg?s=72&d=https%3A%2F%2Fa.slack-edge.com%2Fdf10d%2Fimg%2Favatars%2Fava_0018-72.png",
            "first_name": "Novica",
            "real_name": "Novica",
            "display_name": "",
            "team": "T01DW9DLB2A",
            "name": "nnovica",
            "is_restricted": false,
            "is_ultra_restricted": false
        },
        "attachments": [
            {
                "from_url": "https:\/\/cran.r-project.org\/web\/packages\/cramer\/index.html",
                "thumb_url": "https:\/\/CRAN.R-project.org\/CRANlogo.png",
                "thumb_width": 1000,
                "thumb_height": 1000,
                "service_icon": "https:\/\/cran.r-project.org\/favicon.ico",
                "id": 1,
                "original_url": "https:\/\/cran.r-project.org\/web\/packages\/cramer\/index.html",
                "fallback": "cramer: Multivariate Nonparametric Cramer-Test for the Two-Sample-Problem",
                "text": "Provides R routine for the so called two-sample Cramer-Test. This nonparametric two-sample-test on equality of the underlying distributions can be applied to multivariate data as well as univariate data. It offers two possibilities to approximate the critical value both of which are included in this package.",
                "title": "cramer: Multivariate Nonparametric Cramer-Test for the Two-Sample-Problem",
                "title_link": "https:\/\/cran.r-project.org\/web\/packages\/cramer\/index.html",
                "service_name": "cran.r-project.org"
            }
        ],
        "blocks": [
            {
                "type": "rich_text",
                "block_id": "4iEgW",
                "elements": [
                    {
                        "type": "rich_text_section",
                        "elements": [
                            {
                                "type": "text",
                                "text": "Thanks! I forgot that is possible to have a package that does have an explicit dependency on R -- though there I would have guessed it is a data package.\n\nI got curious about this because of a long discussion with a coworker regarding R versions and packages and decided to have a look how that dependency is  declared on CRAN.\n\nThen i started to see some really weird R version being declared for example: "
                            },
                            {
                                "type": "link",
                                "url": "https:\/\/cran.r-project.org\/web\/packages\/cramer\/index.html"
                            },
                            {
                                "type": "text",
                                "text": " and I wonder if that is then correct or not."
