    {
        "user": "U081Z9041A5",
        "type": "message",
        "ts": "1776168816.964989",
        "edited": {
            "user": "U081Z9041A5",
            "ts": "1776168862.000000"
        },
        "client_msg_id": "651ca390-3047-4341-be15-1f5441141a1d",
        "text": "_Writing R Extensions_ and other resources will make it clear that R only knows `make` and calls it as part of `R CMD INSTALL`.  That is the way it is.\n\nIn the world outside of R, `cmake` is increasingly common and used for many projects as the build system.\n\nThere is zero overlap between the two circles in the Venn diagram I just painted.\n\nWhen _you_ decide to bundle and package a library needing `cmake` then _your package_ calls `cmake` via the R build process which involves R calling `make`.  I pointed you to my `src\/Makevars` because it clearly shows when and where that happens.  We hook into resolving `all`, add a new target and in the target call `cmake` to do our business.",
        "team": "T01DW9DLB2A",
        "user_team": "T01DW9DLB2A",
        "source_team": "T01DW9DLB2A",
        "user_profile": {
            "avatar_hash": "g4e96ca7ae02",
            "image_72": "https:\/\/secure.gravatar.com\/avatar\/4e96ca7ae02c37e7d940d17997d780e5.jpg?s=72&d=https%3A%2F%2Fa.slack-edge.com%2Fdf10d%2Fimg%2Favatars%2Fava_0023-72.png",
            "first_name": "Dirk",
            "real_name": "Dirk Eddelbuettel",
            "display_name": "Dirk Eddelbuettel",
            "team": "T01DW9DLB2A",
            "name": "edd",
            "is_restricted": false,
            "is_ultra_restricted": false
        },
        "thread_ts": "1776164625.075419",
        "parent_user_id": "U060RULT44D",
        "blocks": [
            {
                "type": "rich_text",
                "block_id": "NFh94",
                "elements": [
                    {
                        "type": "rich_text_section",
                        "elements": [
                            {
                                "type": "text",
                                "text": "Writing R Extensions",
                                "style": {
                                    "italic": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " and other resources will make it clear that R only knows "
                            },
                            {
                                "type": "text",
                                "text": "make",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " and calls it as part of "
                            },
                            {
                                "type": "text",
                                "text": "R CMD INSTALL",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": ".  That is the way it is.\n\nIn the world outside of R, "
                            },
                            {
                                "type": "text",
                                "text": "cmake",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " is increasingly common and used for many projects as the build system.\n\nThere is zero overlap between the two circles in the Venn diagram I just painted.\n\nWhen "
                            },
                            {
                                "type": "text",
                                "text": "you",
                                "style": {
                                    "italic": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " decide to bundle and package a library needing "
                            },
                            {
                                "type": "text",
                                "text": "cmake",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": " then "
                            },
                            {
                                "type": "text",
                                "text": "your package",
                                "style": {
                                    "italic": true
                                }
