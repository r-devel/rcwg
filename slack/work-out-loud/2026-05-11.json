            "name": "cgmossa",
            "is_restricted": false,
            "is_ultra_restricted": false
        },
        "thread_ts": "1778532531.011229",
        "parent_user_id": "U07MWC5T8FJ",
        "blocks": [
            {
                "type": "rich_text",
                "block_id": "qTT2i",
                "elements": [
                    {
                        "type": "rich_text_section",
                        "elements": [
                            {
                                "type": "text",
                                "text": "I have to register my rust functions in the same file that rcpp registers it's functions. Currently, either I magically mangle the stub.c or init.c, so that it includes both registry tables, or I can be allowed to have two usedynlib, which means I can just let the registry functions be."
                            }
                        ]
                    }
                ]
            }
        ]
