    {
        "user": "U07MWC5T8FJ",
        "type": "message",
        "ts": "1778533565.569709",
        "client_msg_id": "89a13dd5-16ca-46c8-9b35-c5a1b0034906",
        "text": "I have to register my rust functions in the same file that rcpp registers it's functions. Currently, either I magically mangle the stub.c or init.c, so that it includes both registry tables, or I can be allowed to have two usedynlib, which means I can just let the registry functions be.",
        "team": "T01DW9DLB2A",
        "user_team": "T01DW9DLB2A",
        "source_team": "T01DW9DLB2A",
        "user_profile": {
            "avatar_hash": "gbd5b8649a4e",
            "image_72": "https:\/\/secure.gravatar.com\/avatar\/bd5b8649a4e2d5913c1d2981dc691c79.jpg?s=72&d=https%3A%2F%2Fa.slack-edge.com%2Fdf10d%2Fimg%2Favatars%2Fava_0023-72.png",
