[
    {
        "user": "U07MWC5T8FJ",
        "type": "message",
        "ts": "1778525545.965049",
        "client_msg_id": "2144a590-47fb-4132-bd31-dcac8b534fe7",
        "text": "I am contemplating bringing up a topic on r-devel, and would love some coaching, even if someone want to bring it up.\n\nI propose that CRAN permits more than one usage of  `useDynLib`,  in `NAMESPACE`. The advantages of this are many.\n• We can ship R packages that contains CPU specific features, and then basically load the one we like.\n• We can have R packages that can have C\/C++\/Rust in a very isolated, very clean way.\nThere will be a lot of noise and (valid!) concerns if I bring this up. But there are already excruciating processes in place for publishing on CRAN, and frankly, it wouldn't hurt to have a few more, for the purpose of bringing modularity to native code powered R packages.",
        "team": "T01DW9DLB2A",
        "user_team": "T01DW9DLB2A",
        "source_team": "T01DW9DLB2A",
        "user_profile": {
            "avatar_hash": "gbd5b8649a4e",
            "image_72": "https:\/\/secure.gravatar.com\/avatar\/bd5b8649a4e2d5913c1d2981dc691c79.jpg?s=72&d=https%3A%2F%2Fa.slack-edge.com%2Fdf10d%2Fimg%2Favatars%2Fava_0023-72.png",
            "first_name": "Mossa",
            "real_name": "Mossa",
            "display_name": "Mossa",
            "team": "T01DW9DLB2A",
            "name": "cgmossa",
            "is_restricted": false,
            "is_ultra_restricted": false
        },
        "blocks": [
            {
                "type": "rich_text",
                "block_id": "i1Xtr",
                "elements": [
                    {
                        "type": "rich_text_section",
                        "elements": [
                            {
                                "type": "text",
                                "text": "I am contemplating bringing up a topic on r-devel, and would love some coaching, even if someone want to bring it up.\n\nI propose that CRAN permits more than one usage of  "
                            },
                            {
                                "type": "text",
                                "text": "useDynLib",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": ",  in "
                            },
                            {
                                "type": "text",
                                "text": "NAMESPACE",
                                "style": {
                                    "code": true
                                }
                            },
                            {
                                "type": "text",
                                "text": ". The advantages of this are many.\n"
                            }
                        ]
                    },
                    {
                        "type": "rich_text_list",
                        "elements": [
                            {
                                "type": "rich_text_section",
                                "elements": [
                                    {
                                        "type": "text",
                                        "text": "We can ship R packages that contains CPU specific features, and then basically load the one we like."
                                    }
                                ]
                            },
                            {
                                "type": "rich_text_section",
                                "elements": [
                                    {
                                        "type": "text",
                                        "text": "We can have R packages that can have C\/C++\/Rust in a very isolated, very clean way."
                                    }
                                ]
                            }
                        ],
                        "style": "bullet",
                        "indent": 0,
                        "border": 0
                    },
                    {
                        "type": "rich_text_section",
                        "elements": [
                            {
                                "type": "text",
                                "text": "There will be a lot of noise and (valid!) concerns if I bring this up. But there are already excruciating processes in place for publishing on CRAN, and frankly, it wouldn't hurt to have a few more, for the purpose of bringing modularity to native code powered R packages."
                            }
                        ]
                    }
                ]
            }
        ]
    },
    {
